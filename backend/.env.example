# Use production in Vercel.
NODE_ENV=development
PORT=3333
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require&channel_binding=require

BETTER_AUTH_SECRET=change-me-with-a-long-random-secret
# In production, use the public backend URL (for example, https://api.example.com).
BETTER_AUTH_URL=http://localhost:3333
AUTH_TRUSTED_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000,http://127.0.0.1:19006,http://127.0.0.1:8081,exp://127.0.0.1:8081
ALLOW_PUBLIC_SIGNUP=false

# Google OAuth (callback: http://localhost:3333/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@coracaogaucho.com.br
ADMIN_PASSWORD=ChangeMe123!

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=brl
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3333
N8N_INTEGRATION_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

UPLOAD_MAX_FILE_SIZE_MB=5
# Public frontend origin allowed by CORS. Add every frontend to AUTH_TRUSTED_ORIGINS.
PRODUCTION_ORIGIN=https://admin.coracaogaucho.com.br
